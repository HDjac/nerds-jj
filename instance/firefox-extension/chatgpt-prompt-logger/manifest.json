{
  "manifest_version": 3,
  "name": "NERDS ChatGPT Prompt Logger",
  "version": "0.5",
  "description": "Logs ChatGPT prompts submitted during the NERDS study environment.",
  "permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "http://127.0.0.1:60000/*",
    "http://localhost:60000/*",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-prompt-logger@nerds.local"
    }
  }
}